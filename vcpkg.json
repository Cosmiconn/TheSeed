{
  "name": "theseed-engine",
  "version": "13.2.0",
  "dependencies": [
    "glfw3",
    "imgui",
    "glew",
    "sqlite3",
    "magic-enum",
    "nlohmann-json"
  ],
  "features": {
    "vulkan": {
      "description": "Vulkan renderer support",
      "dependencies": ["vulkan"]
    },
    "editor": {
      "description": "In-engine editor",
      "dependencies": ["imgui"]
    },
    "auth-full": {
      "description": "Full authentication with Argon2id, JWT, PostgreSQL + Redis",
      "dependencies": [
        { "name": "libsodium", "version>=": "1.0.20" },
        { "name": "openssl", "version>=": "3.0" }
      ]
    },
    "auth-postgresql": {
      "description": "PostgreSQL backend for auth service",
      "dependencies": [
        "libpq",
        { "name": "theseed-engine", "default-features": false, "features": ["auth-full"] }
      ]
    },
    "auth-redis": {
      "description": "Redis backend for rate limiting",
      "dependencies": [
        "hiredis",
        { "name": "theseed-engine", "default-features": false, "features": ["auth-full"] }
      ]
    }
  }
}
