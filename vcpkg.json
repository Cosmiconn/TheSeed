{
  "name": "theseed-engine",
  "version": "13.2.0",
  "dependencies": [
    "glfw3",
    "imgui",
    "glew",
    "sqlite3",
    "magic-enum"
  ],
  "features": {
    "vulkan": {
      "description": "Vulkan renderer support",
      "dependencies": ["vulkan"]
    },
    "editor": {
      "description": "In-engine editor",
      "dependencies": ["imgui"]
    },
    "auth-postgresql": {
      "description": "PostgreSQL backend for auth service",
      "dependencies": ["libpq"]
    },
    "auth-redis": {
      "description": "Redis backend for rate limiting",
      "dependencies": ["hiredis"]
    },
    "auth-full": {
      "description": "Full auth with PostgreSQL + Redis",
      "dependencies": [
        { "name": "theseed-engine", "default-features": false, "features": ["auth-postgresql", "auth-redis"] }
      ]
    }
  }
}